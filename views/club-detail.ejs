<!DOCTYPE html>
<html>
<head>
    <title><%= club.name %> - Campus Connect</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f5f5;
        }
        .navbar {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo { font-size: 24px; font-weight: bold; }
        .nav-links { display: flex; gap: 20px; }
        .nav-links a { color: white; text-decoration: none; padding: 8px 15px; border-radius: 5px; }
        .nav-links a:hover { background: rgba(255,255,255,0.2); }
        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }
        .club-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e0e0e0;
        }
        .club-icon {
            font-size: 80px;
            background: #f0f0f0;
            width: 120px;
            height: 120px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .club-info h1 { font-size: 32px; color: #333; }
        .club-info p { color: #666; margin: 5px 0; }
        .members-section {
            margin-bottom: 30px;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 15px;
        }
        .members-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        .member-tag {
            background: #e0e0e0;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 14px;
        }
        .chat-section {
            margin-top: 30px;
        }
        .chat-messages {
            height: 400px;
            overflow-y: auto;
            background: #f8f9fa;
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .message {
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
        }
        .message.sent { align-items: flex-end; }
        .message-bubble {
            max-width: 70%;
            padding: 12px 18px;
            border-radius: 20px;
            background: white;
            color: #333;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .message.sent .message-bubble {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .message-info {
            font-size: 12px;
            color: #999;
            margin-top: 5px;
            margin-left: 10px;
            margin-right: 10px;
        }
        .chat-input {
            display: flex;
            gap: 10px;
        }
        .chat-input input {
            flex: 1;
            padding: 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 16px;
        }
        .chat-input input:focus { outline: none; border-color: #667eea; }
        .chat-input button {
            padding: 0 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
        }
        .join-btn {
            background: #28a745;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 20px;
        }
        .back-link { display: inline-block; margin-top: 20px; color: #667eea; text-decoration: none; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="logo">Campus Connect</div>
        <div class="nav-links">
            <a href="/home">Home</a>
            <a href="/clubs">Clubs</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>
    <div class="container">
        <% if (!isMember && user.role === 'student') { %>
            <button class="join-btn" onclick="joinClub()">Join Club</button>
        <% } %>

        <div class="club-header">
            <div class="club-icon"><%= club.icon || '🎯' %></div>
            <div class="club-info">
                <h1><%= club.name %></h1>
                <p><%= club.description %></p>
                <p>Coordinator: <%= club.coordinator %></p>
                <p>Schedule: <%= club.schedule %></p>
                <p>Venue: <%= club.venue %></p>
                <p>Contact: <%= club.email %></p>
            </div>
        </div>

        <div class="members-section">
            <h3>Members (<%= club.members.length %>)</h3>
            <div class="members-list">
                <% club.members.forEach(member => { %>
                    <span class="member-tag"><%= member.name %></span>
                <% }) %>
            </div>
        </div>

        <% if (isMember) { %>
            <div class="chat-section">
                <h3>Chat</h3>
                <div class="chat-messages" id="chatMessages">
                    <% club.messages.sort((a,b) => new Date(a.timestamp) - new Date(b.timestamp)).forEach(msg => { %>
                        <div class="message <%= msg.userId.toString() === user._id.toString() ? 'sent' : 'received' %>">
                            <div class="message-bubble"><%= msg.message %></div>
                            <div class="message-info"><%= msg.userName %> • <%= new Date(msg.timestamp).toLocaleString() %></div>
                        </div>
                    <% }) %>
                </div>
                <div class="chat-input">
                    <input type="text" id="messageInput" placeholder="Type your message...">
                    <button onclick="sendMessage()">Send</button>
                </div>
            </div>
        <% } %>

        <a href="/clubs" class="back-link">← Back to Clubs</a>
    </div>

    <script>
        const clubId = '<%= club._id %>';

        async function joinClub() {
            const res = await fetch(`/clubs/${clubId}/join`, { method: 'POST' });
            if (res.ok) {
                location.reload();
            } else {
                alert('Error joining club');
            }
        }

        async function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            if (!message) return;

            const res = await fetch(`/clubs/${clubId}/message`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            if (res.ok) {
                input.value = '';
                location.reload(); // Simple refresh to show new message
            } else {
                alert('Error sending message');
            }
        }

        // Scroll chat to bottom on load
        window.onload = function() {
            const chat = document.getElementById('chatMessages');
            if (chat) chat.scrollTop = chat.scrollHeight;
        };
    </script>
</body>
</html>